{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,

  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://ollama:11434/v1"
      },
      "models": {
        "llama3.1:8b": {
          "name": "llama3.1:8b"
        },
        "qwen3.5:cloud": {
          "name": "qwen3.5:cloud"
        },
          "deepseek-v4-pro:cloud": {
          "name": "deepseek-v4-pro:cloud"
        },
          "kimi-k2.6:cloud": {
          "name": "kimi-k2.6:cloud"
        },
          "kimi-k2.5:cloud": {
          "name": "kimi-k2.5:cloud"
        },
          "deepseek-v3.2:cloud": {
          "name": "deepseek-v3.2:cloud"
        },
          "gemma4:e4b": {
          "name": "gemma4:e4b"
        },
          "nemotron-3-ultra:cloud": {
          "name": "nemotron-3-ultra:cloud"
        },
          "glm-5.2:cloud": {
          "name": "glm-5.2:cloud"
        }
      }
    }
  },

  "mcp": {
   "kali-server": {
     "type": "local",
     "command": ["python3", "/opt/MCP-Kali-Server/client.py", "--server", "http://kali-server:5000", "--timeout", "660"],
     "enabled": true,
     "timeout": 720000
   }
  }
}
