{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,

  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "llama3.1:8b": {
          "name": "llama3.1:8b"
        },
        "qwen3.5:cloud": {
          "name": "qwen3.5:cloud"
        },
          "deepseek-v3.2:cloud": {
          "name": "deepseek-v3.2:cloud"
        }
      }
    }
  },

  "mcp": {
   "kali-server": {
     "type": "local",
     "command": ["python3", "/home/jfonteboa/virtual_envs/secagent/MCP-Kali-Server/client.py", "--server", "http://localhost:5000"],
     "enabled": true,
     "timeout": 300000
   }
  }
}

